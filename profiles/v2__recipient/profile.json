{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/recipient.md",
    "description": "Lists recipients with aggregated trailing twelve-month federal spending totals, supporting pagination, sorting, keyword search, and coarse award-type filtering.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/recipient/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "order": {
          "location": "body",
          "type": "string",
          "description": "Sort direction for the chosen field.",
          "constraints": "enum: ['asc','desc']; default: 'desc'; values are case-sensitive"
        },
        "sort": {
          "location": "body",
          "type": "string",
          "description": "Field to sort results by (amount totals or recipient identifiers).",
          "constraints": "enum: ['amount','name','duns','uei']; default: 'amount'"
        },
        "limit": {
          "location": "body",
          "type": "integer",
          "description": "Number of records per page.",
          "constraints": "range 1-1000; default: 50; accepts numeric strings convertible to integers; non-integers return 400; out-of-range returns 422"
        },
        "page": {
          "location": "body",
          "type": "integer",
          "description": "1-indexed page number to retrieve.",
          "constraints": "minimum 1; default: 1; accepts numeric strings convertible to integers; non-integers return 400; values <1 return 422"
        },
        "keyword": {
          "location": "body",
          "type": "string",
          "description": "Full-text search on recipient name, UEI, or DUNS.",
          "constraints": "optional; trims surrounding whitespace; case-insensitive; empty string returns 422; null returns 400; whitespace-only is effectively treated as omitted and yields unfiltered results"
        },
        "award_type": {
          "location": "body",
          "type": "string",
          "description": "High-level award category filter.",
          "constraints": "enum: ['all','contracts','grants','loans','direct_payments','other_financial_assistance']; default: 'all'; values are lowercase only"
        }
      },
      "required": []
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "page_metadata": {
          "type": "object",
          "description": "Pagination metadata for the result set.",
          "required": [
            "page",
            "total",
            "limit",
            "next",
            "previous",
            "hasNext",
            "hasPrevious"
          ],
          "properties": {
            "page": {
              "type": "integer",
              "description": "Current page number (1-indexed)."
            },
            "total": {
              "type": "integer",
              "description": "Total number of matching recipients across all pages."
            },
            "limit": {
              "type": "integer",
              "description": "Effective page size after validation."
            },
            "next": {
              "type": ["integer", "null"],
              "description": "Next page number when additional results exist; null otherwise."
            },
            "previous": {
              "type": ["integer", "null"],
              "description": "Previous page number when a prior page exists; null when unavailable."
            },
            "hasNext": {
              "type": "boolean",
              "description": "True when another page is available."
            },
            "hasPrevious": {
              "type": "boolean",
              "description": "True when a previous page is available."
            }
          }
        },
        "results": {
          "type": "array",
          "description": "Recipient aggregates for the requested slice.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "duns",
              "uei",
              "name",
              "recipient_level",
              "amount"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the recipient at the reported level."
              },
              "duns": {
                "type": ["string", "null"],
                "description": "DUNS identifier when available; null otherwise."
              },
              "uei": {
                "type": ["string", "null"],
                "description": "UEI identifier when available; null otherwise."
              },
              "name": {
                "type": ["string", "null"],
                "description": "Display name, which may be null or an empty string when unavailable."
              },
              "recipient_level": {
                "type": "string",
                "enum": ["R", "P", "C"],
                "description": "Recipient level code: 'R' (recipient), 'P' (parent), or 'C' (child)."
              },
              "amount": {
                "type": "number",
                "description": "Aggregated trailing twelve-month spending total; may be zero or negative."
              }
            }
          }
        }
      },
      "required": ["page_metadata", "results"]
    },
