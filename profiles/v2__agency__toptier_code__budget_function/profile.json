{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/agency/toptier_code/budget_function.md",
    "description": "List budget functions and their subfunctions for a given agency toptier code and fiscal year, including obligated and gross outlay totals.",
    "endpoint": {
      "method": "GET",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/agency/{toptier_code}/budget_function/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "toptier_code": {
          "location": "path",
          "type": "string",
          "description": "Numeric agency toptier code used in the path segment.",
          "constraints": "required; digits only; observed success with 3- and 4-digit values; non-numeric paths return HTML 404"
        },
        "fiscal_year": {
          "location": "query",
          "type": "integer",
          "description": "Fiscal year to report. Defaults to the current fiscal year when omitted.",
          "constraints": "optional; integer between 2008 and 2026 inclusive; numeric strings accepted; decimals or non-integer values return 400; requests before FY2017 return empty data with guidance message"
        },
        "filter": {
          "location": "query",
          "type": "string",
          "description": "Case-insensitive substring filter applied to budget function and subfunction names.",
          "constraints": "optional; empty string behaves like absence; matches restrict both child list and parent totals to hits"
        },
        "order": {
          "location": "query",
          "type": "string",
          "description": "Sort direction for the selected field.",
          "constraints": "optional; enum ['asc','desc']; default 'desc'; invalid values return 400"
        },
        "sort": {
          "location": "query",
          "type": "string",
          "description": "Field to sort results by.",
          "constraints": "optional; enum ['name','obligated_amount','gross_outlay_amount']; default 'obligated_amount'; invalid values return 400"
        },
        "page": {
          "location": "query",
          "type": "integer",
          "description": "One-based page number.",
          "constraints": "optional; minimum 1; default 1; numeric strings accepted; decimals return 400; zero yields 422 below-min error"
        },
        "limit": {
          "location": "query",
          "type": "integer",
          "description": "Maximum results per page.",
          "constraints": "optional; range 1-100 inclusive; default 10; numeric strings accepted; decimals return 400; values above 100 return 422"
        }
      },
      "required": [
        "toptier_code"
      ]
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "toptier_code": {
          "type": "string",
          "description": "Echoes the requested agency toptier code."
        },
        "fiscal_year": {
          "type": "integer",
          "description": "Fiscal year represented in the payload."
        },
        "results": {
          "type": "array",
          "description": "Budget function rollups. May be empty when no data or filters eliminate all matches.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Budget function name."
              },
              "obligated_amount": {
                "type": "number",
                "description": "Total obligations for the function; recalculated to reflect filtered children."
              },
              "gross_outlay_amount": {
                "type": "number",
                "description": "Total gross outlays for the function; recalculated to reflect filtered children."
              },
              "children": {
                "type": "array",
                "description": "Matching budget subfunctions with their own totals.",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Budget subfunction name."
                    },
                    "obligated_amount": {
                      "type": "number",
                      "description": "Obligations attributed to the subfunction."
                    },
                    "gross_outlay_amount": {
                      "type": "number",
                      "description": "Gross outlays attributed to the subfunction."
                    }
                  },
                  "required": [
                    "name",
                    "obligated_amount",
                    "gross_outlay_amount"
                  ]
                }
              }
            },
            "required": [
              "name",
              "obligated_amount",
              "gross_outlay_amount",
              "children"
            ]
          }
        },
        "messages": {
          "type": "array",
          "description": "Array of guidance strings; typically empty but populated for unsupported fiscal years."
        },
        "page_metadata": {
          "type": "object",
          "description": "Pagination metadata including nullable cursors and boolean flags.",
          "properties": {
            "page": {
              "type": "integer",
              "description": "Current page number."
            },
            "total": {
              "type": "integer",
              "description": "Total number of results across all pages."
            },
            "limit": {
              "type": "integer",
              "description": "Requested page size."
            },
            "next": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Next page number when available."
            },
            "previous": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Previous page number when available."
            },
            "hasNext": {
              "type": "boolean",
              "description": "Indicates if another page follows."
            },
            "hasPrevious": {
              "type": "boolean",
              "description": "Indicates if a prior page exists."
            }
          },
          "required": [
            "page",
            "total",
            "limit",
            "next",
            "previous",
            "hasNext",
            "hasPrevious"
          ]
        }
      },
      "required": [
        "toptier_code",
        "fiscal_year",
        "results",
        "messages",
        "page_metadata"
      ]
    },
