    "quirks": [
      "Requests for fiscal years before 2017 return 200 with empty data and a guidance message instead of an error.",
      "The filter parameter matches both budget function and subfunction names, and parent totals recompute to the filtered children.",
      "Limit values above 100 or below 1 trigger 422 validation errors despite documentation omitting the range.",
      "Numeric query parameters accept digit strings but reject decimal inputs with 400 invalid type errors.",
      "Requesting pages beyond available data yields 200 with empty results and metadata reflecting the requested page.",
      "Non-numeric toptier path segments receive an HTML 404 response instead of JSON."
    ],
    "risks": [
      "Pre-FY2017 requests rely on the messages array to explain missing data, so clients must surface those warnings.",
      "Malformed toptier codes can return HTML instead of JSON, requiring defensive parsing.",
      "Financial totals can exceed billions and require high-precision handling to avoid rounding issues.",
      "Validation mixes 400 and 422 responses depending on the failure mode, so integrations must handle both."
    ],
    "gaps": [
      "Unclear whether the filter supports multi-word patterns or operators beyond simple substring matching.",
      "No evidence showing budget functions with empty children arrays or null amount fields; handling of that case is unknown."
    ],
    "confidence": "confirmed",
    "lifecycle": "active",
    "lastVerified": "2026-02-13"
  },
