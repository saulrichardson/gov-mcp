{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/agency/awards/count.md",
    "description": "Return award counts by awarding toptier agency with optional fiscal year, pagination, and CFO-only filtering.",
    "endpoint": {
      "method": "GET",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/agency/awards/count/"
