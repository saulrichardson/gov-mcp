      "confidence": "observed",
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "description": "Observed as nested array where results[0] holds current page rows."
        },
        "page_metadata": {
          "type": "object",
          "description": "Pagination metadata including page, total, next, previous."
        },
        "messages": {
          "type": "array",
          "description": "Warning/info strings, often empty."
        }
      },
      "required": [
        "results",
        "page_metadata",
        "messages"
      ]
    },
    "examples": [
      {
        "request": {
          "method": "GET",
          "path": "/api/v2/agency/awards/count/",
