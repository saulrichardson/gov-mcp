    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "fiscal_year": {
          "location": "query",
          "type": "integer",
          "description": "Appropriations fiscal year.",
          "constraints": "Optional; validated server-side."
        },
        "group": {
          "location": "query",
          "type": "string",
          "description": "Agency subset selector.",
          "constraints": "Optional enum ['all','cfo']."
        },
        "page": {
          "location": "query",
          "type": "integer",
          "description": "1-indexed page.",
          "constraints": "Optional; must be >= 1."
        },
        "limit": {
          "location": "query",
          "type": "integer",
          "description": "Page size.",
          "constraints": "Optional; observed bounds 1..100."
        }
      },
      "required": []
