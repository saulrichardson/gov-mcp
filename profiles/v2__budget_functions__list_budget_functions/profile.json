    "quirks": [
      "Requests without the trailing slash receive an HTTP 301 redirect to the canonical path.",
      "Supplying the DRF format query parameter (e.g., format=csv) returns HTTP 404 instead of JSON.",
      "Requests with Accept headers that exclude application/json (e.g., Accept: application/xml) receive HTTP 406."
    ],
    "risks": [
      "Endpoint always returns the full unpaginated list; clients must tolerate the entire payload and handle potential catalog growth.",
      "Clients that omit application/json in the Accept header will receive HTTP 406 and no data.",
      "Using the reserved format query parameter causes HTTP 404, so integrations must avoid that key."
    ],
    "gaps": [
      "Unknown whether the number of budget function entries or their ordering can change over time.",
      "No evidence of officially supported query parameters beyond the default JSON variant."
    ],
