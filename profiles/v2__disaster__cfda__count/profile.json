      },
      "notes": "Unrecognized filter key is tolerated and ignored."
    },
    {
      "request": {
        "method": "POST",
        "path": "/api/v2/disaster/cfda/count/",
        "query": {},
        "body": {
          "filter": {
            "def_codes": ["QQQ"]
          }
        }
      },
      "response": {
        "status": 200,
        "bodyExcerpt": "{\"count\":0}",
        "contentType": "application/json"
      },
      "notes": "Rare DEFC such as QQQ accepted and returns zero count."
    },
    {
      "request": {
        "method": "POST",
