    "quirks": [
      "Null, empty, or omitted budget_function returns the full catalog instead of raising an error.",
      "Unrecognized, mistyped, or non-string budget_function values return an empty results array with HTTP 200.",
      "Trailing whitespace is not trimmed; for example '050 ' returns an empty list.",
      "The budget_function filter is only honored when the request uses Content-Type: application/json; other media types such as text/plain receive HTTP 415, and missing the header causes the backend to ignore the filter and return the full catalog."
    ],
    "risks": [
      "Clients expecting validation errors for malformed budget_function inputs will instead receive empty results, which can hide mistakes.",
      "Missing or incorrect Content-Type headers cause the endpoint to ignore the budget_function filter, making it easy to fetch the full catalog unintentionally."
    ],
    "gaps": [
      "Complete enumeration of accepted budget_function codes is undocumented; only a subset (050, 800, 990) has been verified via probes."
    ],
    "confidence": "confirmed",
    "lifecycle": "active",
    "lastVerified": "2026-02-13"
  },
