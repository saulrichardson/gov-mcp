{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/budget_functions/list_budget_subfunctions.md",
    "description": "Retrieve budget subfunctions, optionally filtered by a three-digit, zero-padded budget function code, with results sorted by title ascending.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/budget_functions/list_budget_subfunctions/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "budget_function": {
          "location": "body",
          "type": "string",
          "description": "Optional zero-padded budget function code limiting the returned subfunctions to a single budget function.",
          "constraints": "Optional. Provide a three-digit, zero-padded code string. Observed working values include '050', '800', and '990'. Null, empty, or omitted values return the full catalog. Unrecognized or wrongly formatted values yield an empty list without error. The filter only applies when the request declares Content-Type: application/json."
        }
      },
      "required": []
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "description": "Array of budget subfunction objects sorted ascending by budget_subfunction_title.",
          "items": {
            "type": "object",
            "properties": {
              "budget_subfunction_code": {
                "type": "string",
                "description": "Three-digit budget subfunction code."
              },
              "budget_subfunction_title": {
                "type": "string",
                "description": "Human-readable name of the budget subfunction."
              }
            },
            "required": [
              "budget_subfunction_code",
              "budget_subfunction_title"
            ]
          }
        }
      },
      "required": [
        "results"
      ]
    },
    "examples": [
