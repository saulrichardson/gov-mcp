        "name": "baseline_transactions_count",
        "description": "Count the transaction-level download population for one fiscal-year date range using the endpoint default spending_level.",
        "request": {
          "method": "POST",
          "path": "/api/v2/download/count/",
          "query": {},
          "body": {
            "filters": {
              "time_period": [
                {
                  "start_date": "2022-10-01",
                  "end_date": "2023-09-30"
                }
              ]
            }
          }
        },
        "evidenceRefs": [
          "ev-live-baseline-default"
        ]
      },
      {
        "name": "award_level_preflight_count",
        "description": "Count award-level rows for the same filters before attempting an award-level row-limited download.",
