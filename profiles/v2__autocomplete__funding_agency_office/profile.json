{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/autocomplete/funding_agency_office.md",
    "description": "Autocomplete endpoint returning funding agencies, sub-tier agencies, and offices that match a search term.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/autocomplete/funding_agency_office/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "search_text": {
          "location": "body",
          "type": "string",
          "description": "Search term to match top-tier agencies, sub-tier agencies, and offices. The backend stringifies any non-null JSON value before searching, so unexpected inputs can return surprising matches.",
          "constraints": "Required; null or empty string returns 400 'Missing one or more required request parameters: search_text'. Whitespace-only strings succeed and yield broad office matches. Non-string values are coerced instead of rejected, so callers should validate client-side."
        },
        "limit": {
          "location": "body",
          "type": "integer",
          "description": "Optional per-category result cap applied independently to the toptier_agency, subtier_agency, and office arrays.",
          "constraints": "Optional; omit to accept the server default (exact cap not confirmed). Zero returns empty arrays. Positive integers return up to that many items per list. Negative integers suppress top-tier results while still returning sub-tier and office matches. Numeric strings, floats, and booleans are coerced via Python int semantics; non-numeric strings return 400; null or object values trigger HTML 500 responses."
        }
      },
      "required": [
        "search_text"
      ]
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "results": {
          "type": "object",
          "description": "Collections of matches grouped by entity type; the limit applies separately to each array.",
          "properties": {
            "toptier_agency": {
              "type": "array",
              "description": "Matched top-tier agencies. Abbreviation may be null and the offices list may be empty even when the agency matches.",
              "items": {
                "type": "object",
                "properties": {
                  "abbreviation": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "code": {
