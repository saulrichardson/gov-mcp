    "quirks": [
      "Omitting sort or requesting sort='id' triggers a warning and the backend sorts by description instead.",
      "String-based sort fields such as 'description' or 'code' do not consistently honor the requested order.",
      "totals.award_count can report 0 while individual result rows show positive counts (observed with DEFC Q).",
      "page_metadata.total is capped at 10,000 for large result sets, limiting accessible recipients.",
      "spending_type is accepted but ignored by the backend."
    ],
    "risks": [
      "Clients relying on string sorting (description/code) may receive unsorted data and should re-order client-side.",
      "Aggregate counts in totals may conflict with per-recipient award_count values, which can mislead downstream summaries.",
      "The 10,000 record ceiling in page_metadata.total can hide additional recipients unless callers refine their filters.",
      "Default requests emit warning messages; callers should explicitly choose a supported sort field to avoid fallback behavior."
    ],
    "gaps": [
      "The optional 'children' array documented for results was not observed; hierarchical responses remain unverified."
    ],
    "confidence": "confirmed",
    "lifecycle": "active",
    "lastVerified": "2026-02-13"
  },
