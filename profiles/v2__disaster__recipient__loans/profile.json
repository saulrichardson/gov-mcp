{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/disaster/recipient/loans.md",
    "description": "Aggregates disaster loan recipients and totals filtered by Disaster Emergency Fund (DEFC) codes with optional keyword and loan-type constraints.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/disaster/recipient/loans/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "required": [
        "filter"
      ],
      "properties": {
        "filter": {
          "location": "body",
          "type": "object",
          "description": "Required DEFC filter object with optional loan award type and keyword refinements.",
          "required": [
            "def_codes"
          ],
          "properties": {
            "def_codes": {
              "type": "array",
              "description": "List of Disaster Emergency Fund codes to include (uppercase tokens).",
              "constraints": "Required; array must contain at least one value; allowed values ['1','2','3','4','5','6','7','8','9','A','AAA','AAB','AAC','AAD','AAE','AAF','AAG','AAH','AAI','AAJ','AAK','AAL','B','C','D','E','F','G','H','I','J','K','L','M','N','O','P','Q','QQQ','R','S','T','U','V','W','X','Y','Z']; non-array inputs or unlisted codes return 400; empty arrays return 422."
            },
            "award_type_codes": {
              "type": "array",
              "description": "Optional loan award type filter restricted to loan codes.",
              "constraints": "Optional; when provided must be a non-empty array containing only '07' and/or '08'; invalid codes return 400; empty arrays return 422."
            },
            "query": {
              "type": [
                "string",
                "null"
              ],
              "description": "Optional keyword matched against recipient names/descriptions.",
              "constraints": "Optional; accepts null or non-empty strings; empty strings return 422; non-text inputs (arrays, numbers) return 400."
            }
          }
        },
        "pagination": {
          "location": "body",
          "type": "object",
          "description": "Optional pagination and sorting controls.",
          "properties": {
            "page": {
              "type": "integer",
              "description": "1-indexed results page number.",
              "constraints": "Optional; defaults to 1; must be an integer >= 1; zero returns 422; non-integer values return 400."
            },
            "limit": {
              "type": "integer",
              "description": "Number of recipients returned per page.",
              "constraints": "Optional; defaults to 10; must be between 1 and 100 inclusive; zero or negatives return 422; values above 100 return 422; non-integer values return 400."
            },
            "order": {
              "type": "string",
              "description": "Sort direction for the selected field.",
              "constraints": "Optional; accepts only lowercase 'asc' or 'desc'; defaults to 'desc'; other casings (e.g., 'ASC') return 400."
            },
            "sort": {
              "type": "string",
              "description": "Field used to order the results.",
              "constraints": "Optional; valid values ['award_count','description','code','id','obligation','outlay','face_value_of_loan']; omitting this field or requesting 'id' yields a warning and the backend actually sorts by 'description'."
            }
          }
        },
        "spending_type": {
          "location": "body",
          "type": [
            "string",
            "null"
          ],
          "description": "Optional label parameter accepted but ignored by the backend.",
          "constraints": "Any string or null succeeds without changing the response."
        }
      }
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "required": [
        "totals",
        "results",
        "page_metadata"
      ],
      "properties": {
        "totals": {
          "type": "object",
          "description": "Aggregate metrics for the filtered dataset.",
          "required": [
            "obligation",
            "outlay",
            "face_value_of_loan",
            "award_count"
          ],
          "properties": {
            "obligation": {
              "type": "number"
            },
            "outlay": {
              "type": "number"
            },
            "face_value_of_loan": {
              "type": "number"
            },
            "award_count": {
              "type": "number",
              "description": "Total loan award count; observed to report 0 for DEFC Q even when individual rows show positive counts."
            }
          }
        },
        "results": {
          "type": "array",
          "description": "Per-recipient loan aggregates that match the filter criteria.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "code",
              "description",
              "award_count",
              "obligation",
              "outlay",
              "face_value_of_loan"
            ],
            "properties": {
              "id": {
                "type": "array",
                "description": "List of contributing award identifiers (observed lengths 1-2; IDs carry '-R'/'-C' suffixes)."
              },
              "code": {
                "type": "string",
                "description": "Recipient identifier such as DUNS or the literal 'DUNS Number not provided'."
              },
              "description": {
                "type": "string",
                "description": "Recipient name."
              },
              "award_count": {
                "type": "number"
              },
              "obligation": {
                "type": "number"
              },
              "outlay": {
                "type": "number"
              },
              "face_value_of_loan": {
                "type": "number"
              }
            }
          }
        },
        "page_metadata": {
          "type": "object",
          "description": "Pagination metadata for the current response page.",
          "required": [
            "page",
            "total",
            "limit",
            "next",
            "previous",
            "hasNext",
            "hasPrevious"
          ],
          "properties": {
            "page": {
              "type": "number"
            },
            "total": {
              "type": "number",
              "description": "Total recipients returned by the backend; observed to cap at 10000 for large result sets."
            },
            "limit": {
              "type": "number"
            },
            "next": {
              "type": [
                "number",
                "null"
              ]
            },
            "previous": {
              "type": [
                "number",
                "null"
              ]
            },
            "hasNext": {
              "type": "boolean"
            },
            "hasPrevious": {
              "type": "boolean"
            }
          }
        },
        "messages": {
          "type": "array",
          "description": "Optional warning messages, currently emitted when the backend falls back from an unsupported sort.",
          "items": {
            "type": "string"
          }
        }
      }
    },
