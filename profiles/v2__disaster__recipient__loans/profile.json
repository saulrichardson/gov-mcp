  "mismatches": [
    "Documentation spells the totals field 'face_value_of_laon' and implies string values, but the API responds with numeric 'face_value_of_loan'.",
    "Docs list sort options ['description','award_count','face_value_of_loan','obligation','outlay']; the live API also accepts 'code' and 'id' (with id emitting a warning).",
    "Documentation states description is the default sort, yet the backend attempts sort='id' and falls back to description with a warning when sort is omitted."
  ],
  "gaps": [
    "Unable to confirm presence or shape of the optional 'children' array described in the docs."
  ],
  "risks": [
    "String sorting on 'description' or 'code' may not reflect the requested order; clients should re-sort locally.",
    "Totals.award_count can disagree with per-recipient award_count values, risking misleading aggregate displays.",
    "page_metadata.total stops at 10,000, so callers must filter further to access deeper records.",
    "Default sort fallback generates warnings; integrations should always set a supported sort field."
  ]
