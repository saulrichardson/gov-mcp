    "quirks": [
      "Default page size is 5 results despite documentation examples showing 10.",
      "Sort defaults to 'federal_account' descending; providing only 'order' flips the direction while retaining the default sort field.",
      "Validation errors mix HTTP 400 for type issues and 422 for missing or out-of-range values.",
      "Unknown award identifiers return 200 with empty results instead of an error."
    ],
    "risks": [
      "Clients must handle both 400 and 422 validation responses depending on the failure type.",
      "Pagination continues to return 200 with empty pages, so stop conditions should rely on page_metadata.hasNext/hasPrevious.",
      "Inputs that validate syntactically (e.g., numeric award IDs) can still return empty results, so integrations should confirm non-empty payloads."
    ],
    "gaps": [
      "Unverified whether funding agency fields in results can be null despite documentation marking them nullable."
    ],
    "confidence": "confirmed",
