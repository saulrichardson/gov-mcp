{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/awards/accounts.md",
    "description": "Returns federal accounts associated with a specific award including obligated amounts and funding agency metadata.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/awards/accounts/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "award_id": {
          "location": "body",
          "type": [
            "string",
            "integer"
          ],
          "description": "Unique award identifier to scope the lookup.",
          "constraints": "Required; accepts strings or integers. Empty strings, null, and boolean inputs return 422 errors. Unknown identifiers return 200 with empty results."
        },
        "page": {
          "location": "body",
          "type": "integer",
          "description": "1-indexed results page.",
          "constraints": "Optional; defaults to 1. Must be an integer greater than or equal to 1. Non-integer values return 400; integers below 1 return 422."
        },
        "limit": {
          "location": "body",
          "type": "integer",
          "description": "Maximum results per page.",
          "constraints": "Optional; defaults to 5. Must be an integer between 1 and 100 inclusive. Non-integers return 400; values outside the range return 422."
        },
        "order": {
          "location": "body",
          "type": "string",
          "description": "Sort direction applied to the selected sort field.",
          "constraints": "Optional; defaults to 'desc'. Allowed values are 'asc' and 'desc' (case-sensitive). Other inputs, including null, return 400."
        },
        "sort": {
          "location": "body",
          "type": "string",
          "description": "Field used to order results.",
          "constraints": "Optional; defaults to 'federal_account'. Allowed values are 'federal_account', 'total_transaction_obligated_amount', 'agency', and 'account_title'. Other inputs, including null, return 400."
        }
      },
      "required": [
        "award_id"
      ]
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "description": "List of federal accounts associated with the specified award.",
          "items": {
            "type": "object",
            "properties": {
              "total_transaction_obligated_amount": {
                "type": "number"
              },
              "federal_account": {
                "type": "string"
              },
              "account_title": {
                "type": "string"
              },
              "funding_agency_abbreviation": {
                "type": "string"
              },
              "funding_agency_name": {
                "type": "string"
              },
              "funding_agency_id": {
                "type": "integer"
              },
              "funding_toptier_agency_id": {
                "type": "integer"
              },
              "funding_agency_slug": {
                "type": "string"
              }
            },
            "required": [
              "total_transaction_obligated_amount",
              "federal_account",
              "account_title",
              "funding_agency_abbreviation",
              "funding_agency_name",
              "funding_agency_id",
              "funding_toptier_agency_id",
              "funding_agency_slug"
            ]
          }
        },
        "page_metadata": {
          "type": "object",
          "description": "Pagination metadata for the result set.",
          "properties": {
            "page": {
              "type": "integer"
            },
            "count": {
              "type": "integer"
            },
            "next": {
              "type": [
                "integer",
                "null"
              ]
            },
            "previous": {
              "type": [
                "integer",
                "null"
              ]
            },
            "hasNext": {
              "type": "boolean"
            },
            "hasPrevious": {
              "type": "boolean"
            }
          },
          "required": [
            "page",
            "count",
            "next",
            "previous",
            "hasNext",
            "hasPrevious"
          ]
        }
      },
      "required": [
        "results",
        "page_metadata"
      ]
    },
