{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/autocomplete/awarding_agency_office.md",
    "description": "Autocomplete awarding agencies, sub-agencies, and offices matching a search term and return related hierarchy context.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/autocomplete/awarding_agency_office/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "search_text": {
          "location": "body",
          "type": "string",
          "description": "Case-insensitive search string for agency, sub-agency, or office names and abbreviations.",
          "constraints": "Required. Missing, null, or empty strings return 400 'Missing one or more required request parameters: search_text'. Comparison is literal: leading/trailing spaces or whitespace-only inputs change results. Non-string JSON values are coerced to their string form before matching."
        },
        "limit": {
          "location": "body",
          "type": "integer",
          "description": "Maximum number of matches returned per category array.",
          "constraints": "Optional. Defaults to 10 per category when omitted. Numeric strings are coerced, floats are truncated, and 0 returns empty arrays. Negative integers still return 200 but omit some categories and flood others. Setting limit to null triggers a 500 HTML error, and non-numeric strings return 400 'Limit request parameter is not a valid, positive integer'. Large positive values saturate near 601 office entries."
        }
      },
      "required": [
        "search_text"
      ]
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "required": [
        "results",
        "messages"
      ],
