{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/disaster/object_class/count.md",
    "description": "Counts the number of object classes that received disaster/emergency funding for the provided Disaster Emergency Fund Code filters.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/disaster/object_class/count/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "filter": {
          "location": "body",
          "type": "object",
          "description": "Top-level request filter; must supply a def_codes array. Additional keys (shared search filters or arbitrary fields) are accepted but ignored.",
          "constraints": "Required object containing def_codes; server ignores unknown fields but enforces the def_codes array.",
          "properties": {
            "def_codes": {
              "location": "body",
              "type": "array",
              "description": "Disaster Emergency Fund Codes whose union determines the counted object classes.",
              "items": {
                "type": "string",
                "enum": [
                  "1",
                  "2",
                  "3",
                  "4",
                  "5",
                  "6",
                  "7",
                  "8",
                  "9",
                  "A",
                  "AAA",
                  "AAB",
                  "AAC",
                  "AAD",
                  "AAE",
                  "AAF",
                  "AAG",
                  "AAH",
                  "AAI",
                  "AAJ",
                  "AAK",
                  "AAL",
                  "B",
                  "C",
                  "D",
                  "E",
                  "F",
                  "G",
                  "H",
                  "I",
                  "J",
                  "K",
                  "L",
                  "M",
                  "N",
                  "O",
                  "P",
                  "Q",
                  "QQQ",
                  "R",
                  "S",
                  "T",
                  "U",
                  "V",
                  "W",
                  "X",
                  "Y",
                  "Z"
                ]
              },
              "minItems": 1,
              "constraints": "Required; duplicates allowed. 400 if an item falls outside the allow-list or is not a string. 422 when the array is empty or missing. Mixing valid codes with nulls or numbers triggers a 500 HTML error response."
            },
            "time_period": {
              "location": "body",
              "type": [
                "array",
                "null"
              ],
              "description": "Optional shared filter accepted without effect on the count.",
              "constraints": "Optional; accepts empty arrays, partial ranges, malformed dates, or null and still returns the same count."
            },
            "award_type_codes": {
              "location": "body",
              "type": "array",
              "description": "Optional shared filter accepted without effect on the count.",
              "items": {
                "type": "string"
              },
              "constraints": "Optional; accepts empty arrays and invalid codes without changing results or raising errors."
            }
          },
          "required": [
            "def_codes"
          ],
          "additionalProperties": true
        }
      },
      "required": [
        "filter"
      ]
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of object classes that match the provided DEFC filters; zero indicates no qualifying object classes."
        }
      },
      "required": [
        "count"
      ]
    },
    "examples": [
      {
        "request": {
          "method": "POST",
          "path": "/api/v2/disaster/object_class/count/",
          "query": {},
          "body": {
            "filter": {
              "def_codes": [
                "L",
                "M",
                "N"
              ]
            }
          }
        },
        "response": {
          "status": 200,
          "body": {
            "count": 35
          }
        }
      },
      {
        "request": {
          "method": "POST",
          "path": "/api/v2/disaster/object_class/count/",
