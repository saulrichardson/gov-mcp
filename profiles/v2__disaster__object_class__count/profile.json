          "body": {
            "filter": {
              "def_codes": [
                "QQQ"
              ]
            }
          }
        },
        "response": {
          "status": 200,
          "body": {
            "count": 0
          }
        }
      },
      {
        "request": {
          "method": "POST",
          "path": "/api/v2/disaster/object_class/count/",
          "query": {},
          "body": {
            "filter": {
              "def_codes": [
                "ZZ"
              ]
            }
          }
        },
        "response": {
          "status": 400,
          "body": {
            "detail": "Field 'filter|def_codes' is outside valid values ['1', '2', '3', '4', '5', '6', '7', '8', '9', 'A', 'AAA', 'AAB', 'AAC', 'AAD', 'AAE', 'AAF', 'AAG', 'AAH', 'AAI', 'AAJ', 'AAK', 'AAL', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J', 'K', 'L', 'M', 'N', 'O', 'P', 'Q', 'QQQ', 'R', 'S', 'T', 'U', 'V', 'W', 'X', 'Y', 'Z']"
          }
        }
      },
      {
        "request": {
          "method": "POST",
          "path": "/api/v2/disaster/object_class/count/",
          "query": {},
          "body": {
            "filter": {
              "def_codes": [
                "L",
                null
              ]
            }
          }
        },
        "response": {
          "status": 500,
          "body": "<!doctype html>...Server Error (500)..."
        }
      }
    ],
    "quirks": [
      "Only filter.def_codes is enforced; other filter fields or arbitrary keys are accepted without affecting the count.",
      "Shared filters such as time_period and award_type_codes are ignored even when null, empty, malformed, or containing invalid values.",
      "Validation returns 400 for disallowed values or types and 422 for missing or empty def_codes, but mixing valid codes with nulls or numbers yields a 500 HTML response."
    ],
    "risks": [
      "Consumers may assume supplemental filters (time_period, award_type_codes, etc.) work even though the API ignores them, leading to misinterpreted analytics.",
      "The DEFC allow-list is hard-coded; newly introduced codes may be rejected until the backend is updated.",
      "Malformed def_codes arrays that mix valid strings with nulls or numbers can trigger a 500 HTML response, so clients must sanitize lists before submission."
    ],
    "gaps": [],
    "confidence": "confirmed",
    "lifecycle": "active",
    "lastVerified": "2026-02-13"
  },
