{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/disaster/federal_account/spending.md",
    "description": "Returns aggregated disaster and emergency spending totals grouped by federal account and nested treasury account symbols for the supplied DEFC filters.",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/disaster/federal_account/spending/"
    },
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "filter": {
          "location": "body",
          "type": "object",
          "description": "Filter object that must include disaster emergency fund (DEFC) codes. A query string key is accepted but produced no observable change in results.",
          "required": [
            "def_codes"
          ],
          "properties": {
            "def_codes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "1",
                  "2",
                  "3",
                  "4",
                  "5",
                  "6",
                  "7",
                  "8",
                  "9",
                  "A",
                  "AAA",
                  "AAB",
                  "AAC",
                  "AAD",
                  "AAE",
                  "AAF",
                  "AAG",
                  "AAH",
                  "AAI",
                  "AAJ",
                  "AAK",
                  "AAL",
                  "B",
                  "C",
                  "D",
                  "E",
                  "F",
                  "G",
                  "H",
                  "I",
                  "J",
                  "K",
                  "L",
                  "M",
                  "N",
                  "O",
                  "P",
                  "Q",
                  "QQQ",
                  "R",
                  "S",
                  "T",
                  "U",
                  "V",
                  "W",
                  "X",
                  "Y",
                  "Z"
                ]
              },
              "minItems": 1,
              "description": "Uppercase DEFC codes; empty arrays or lowercase strings are rejected."
            },
            "query": {
              "type": "string",
              "description": "Optional keyword string accepted by the API but ignored in all observed responses."
            }
          },
          "constraints": "Must include def_codes with at least one uppercase value from the server allowlist; missing or empty arrays return 422, invalid values return 400."
        },
        "spending_type": {
          "location": "body",
          "type": "string",
          "description": "Selects whether obligation and outlay amounts represent total resources or award-derived values.",
          "enum": [
            "total",
            "award"
          ],
          "constraints": "Required. Any value outside ['total','award'] returns 400.",
          "effects": "Mode controls which response fields are populated versus null (see output schema)."
        },
        "pagination": {
          "location": "body",
          "type": "object",
          "description": "Optional pagination and sorting controls applied to the account list.",
          "properties": {
            "page": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Page number (integers only). Zero or negatives return 422; decimals return 400."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10,
              "description": "Page size. Values below 1 or above 100 return 422."
            },
            "order": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc",
              "description": "Sort direction. Unsupported values return 400."
            },
            "sort": {
              "type": "string",
              "enum": [
                "id",
                "code",
                "description",
                "award_count",
                "obligation",
                "outlay",
                "total_budgetary_resources"
              ],
              "default": "id",
              "description": "Sort field. Unsupported values return 400."
            }
          },
          "constraints": "Numeric strings such as \"1\" are coerced, but non-integer numbers (e.g., 1.5) are rejected with 400 errors."
        }
      },
      "required": [
        "filter",
        "spending_type"
      ]
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "description": "Federal account rows matching the DEFC filters. Each row includes nested TAS children with the same shape.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "code": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "award_count": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "obligation": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Obligation totals for the row; may be negative in award mode."
              },
              "outlay": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "total_budgetary_resources": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "children": {
                "type": "array",
                "description": "Nested TAS entries mirroring the parent fields and nullability rules.",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "code": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "award_count": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "obligation": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "outlay": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "total_budgetary_resources": {
                      "type": [
                        "number",
                        "null"
                      ]
                    }
                  }
                }
              }
            },
            "description": "When spending_type='total', award_count values are null and total_budgetary_resources is populated; when spending_type='award', award_count is numeric and total_budgetary_resources is null."
          }
        },
        "page_metadata": {
          "type": "object",
          "description": "Pagination metadata; total reflects all matches even when the current page is empty.",
          "properties": {
            "page": {
              "type": "number"
            },
            "total": {
              "type": "number"
            },
            "limit": {
              "type": "number"
            },
            "next": {
              "type": [
                "number",
                "null"
              ]
            },
            "previous": {
              "type": [
                "number",
                "null"
              ]
            },
            "hasNext": {
              "type": "boolean"
            },
            "hasPrevious": {
              "type": "boolean"
            }
          }
        },
        "totals": {
          "type": "object",
          "description": "Aggregate obligations and outlays across the filtered dataset. total_budgetary_resources appears only in total mode; award_count appears only in award mode.",
          "properties": {
            "obligation": {
              "type": "number"
            },
            "outlay": {
              "type": "number"
            },
            "total_budgetary_resources": {
              "type": [
                "number",
                "null"
              ]
            },
            "award_count": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        }
      },
      "required": [
        "results",
        "page_metadata",
        "totals"
      ]
    },
