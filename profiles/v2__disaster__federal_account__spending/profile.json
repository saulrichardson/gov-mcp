    "quirks": [
      "filter.query is accepted but has no observable impact on totals or result sets.",
      "Response fields flip between numeric and null depending on spending_type (award_count null in total mode; total_budgetary_resources null in award mode) for both accounts and their children.",
      "Numeric pagination inputs must be integers: decimal values raise 400 errors even when numeric strings are accepted."
    ],
    "risks": [
      "Clients assuming server-side keyword filtering will be disappointed until the query parameter behavior is clarified.",
      "Integrators must tolerate nulls for award_count or total_budgetary_resources depending on spending_type to avoid type errors.",
      "User-supplied pagination values should be sanitized to avoid 400/422 validation errors (e.g., page <1, limit>100, decimal inputs)."
    ],
    "gaps": [
      "Still unclear what backend fields filter.query is intended to search; it produced no effect in any probe."
    ],
    "confidence": "confirmed",
    "lifecycle": "active",
    "lastVerified": "2026-02-13"
  },
