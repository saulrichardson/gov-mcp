{
  "name": "codex-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex SDK raw-profile pipeline plus shared semantic bundle validator",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "discover": "tsx src/discover.ts",
    "validate": "tsx src/validate.ts",
    "reconcile": "tsx src/reconcile.ts",
    "profile": "tsx src/reconcile.ts",
    "semantic:validate": "tsx src/semanticValidate.ts",
    "preflight": "tsx src/preflight.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@openai/codex-sdk": "^0.101.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.15.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
