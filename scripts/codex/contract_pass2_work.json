{
  "schemaVersion": "1.0.0",
  "contract": {
    "name": "v2/download/contract.md",
    "endpoint": {
      "method": "POST",
      "host": "https://api.usaspending.gov",
      "path": "/api/v2/download/contract/"
    },
    "description": "Creates a download job for a specific contract award and returns the generated file metadata plus the backend request snapshot.",
    "inputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "award_id": {
          "location": "body",
          "type": [
            "string",
            "integer"
          ],
          "description": "Identifier of the target contract award. Accepts canonical contract award strings (e.g., 'CONT_AWD_...') and the internal numeric award identifier.",
          "constraints": "required; rejects null or empty strings; must resolve to an existing contract award; string values may be purely numeric but still execute the lookup."
        },
        "file_format": {
          "location": "body",
          "type": "string",
          "description": "Optional override for the archive format applied to all files in the download.",
          "constraints": "optional; default 'csv'; accepts only lowercase ['csv','tsv','pstxt']; other strings return 400 with an enumerated error; non-string JSON values such as null or numbers currently trigger an internal 500 HTML error."
        }
      },
      "required": [
        "award_id"
      ]
    },
    "outputSchema": {
      "confidence": "observed",
      "type": "object",
      "properties": {
        "status_url": {
          "type": "string",
          "description": "Absolute https endpoint for polling the download job status, with file_name passed as query."
        },
        "file_name": {
          "type": "string",
          "description": "Generated archive name in the form CONT_<PIID>_<timestamp>.zip"
        },
        "file_url": {
          "type": "string",
          "description": "Absolute https URL where the generated archive is published once the job finishes."
        },
        "download_request": {
          "type": "object",
          "description": "Snapshot of the effective backend download configuration for the created job.",
          "properties": {
            "account_level": {
              "type": "string",
              "description": "Aggregation level used for download datasets (treasury_account observed)."
            },
            "award_id": {
              "type": "integer",
              "description": "Internal numeric award identifier associated with the request."
            },
            "download_types": {
              "type": "array",
              "description": "List of dataset identifiers included in the archive; observed to always be the contract trio",
              "items": {
                "type": "string"
              }
            },
            "file_format": {
              "type": "string",
              "description": "Format applied to generated files, echoing the requested or default format."
            },
            "filters": {
              "type": "object",
              "description": "Filter block applied to the download; award_id is the numeric internal id and award_type_codes prefill to contract codes.",
              "properties": {
                "award_id": {
                  "type": "integer",
                  "description": "Internal award identifier used for filtering."
                },
                "award_type_codes": {
                  "type": "array",
                  "description": "Contract award type codes automatically applied (A, B, C, D).",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "include_data_dictionary": {
              "type": "boolean",
              "description": "Whether the archive includes the contract data dictionary file."
            },
            "include_file_description": {
              "type": "object",
              "description": "Metadata describing the supplemental readme file packaged with the download.",
              "properties": {
                "destination": {
                  "type": "string",
                  "description": "Filename used inside the archive."
                },
                "source": {
                  "type": "string",
                  "description": "Backend source path for the supplemental file."
                }
              }
            },
            "is_for_assistance": {
              "type": "boolean",
              "description": "Flag indicating the job targets assistance data (false for these responses)."
            },
            "is_for_contract": {
              "type": "boolean",
              "description": "Flag confirming the job targets contract data (true observed)."
            },
            "is_for_idv": {
              "type": "boolean",
              "description": "Flag indicating whether the job is for an IDV award (false observed)."
            },
            "limit": {
              "type": "integer",
              "description": "Row cap applied to datasets generated by the job."
            },
            "piid": {
              "type": "string",
              "description": "Contract PIID associated with the award."
            },
            "request_type": {
              "type": "string",
              "description": "Request type descriptor (contract observed)."
            }
          }
        }
      },
      "required": [
        "status_url",
        "file_name",
        "file_url",
        "download_request"
      ]
    },
    "examples": [
