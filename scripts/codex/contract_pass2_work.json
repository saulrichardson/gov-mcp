    "quirks": [
      "Response file_name pattern is CONT_<PIID>_<timestamp>.zip without the _transactions/_awards suffix described in the contract doc.",
      "API accepts numeric and numeric-string award IDs even though the docs only describe string values.",
      "Additional body keys such as download_types are ignored; the job configuration reverts to the default contract dataset trio.",
      "status_url and file_url are returned as absolute https URLs, not the relative/localhost examples shown in the markdown.",
      "The production IPv6 endpoint closes connections without a response; forcing IPv4 (e.g., curl -4) is required to receive JSON replies.",
      "Null or numeric file_format values surface a 500 HTML error instead of a JSON validation response."
    ],
    "confidence": "observed"
  },
