#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/../../.." && pwd)
stdio_server="$repo_root/scripts/mcp/bin/stdio-server"

cat <<EOF
Repo: $repo_root
Server: $stdio_server

---
Claude Code (.mcp.json)

- This repo already includes .mcp.json configured for this server.
- If you need an absolute path instead, use:

{
  "mcpServers": {
    "usaspending": {
      "command": "$stdio_server",
      "args": []
    }
  }
}

---
Cursor (.cursor/mcp.json)

- This repo already includes .cursor/mcp.json configured for this server.

---
Claude Desktop (macOS)

File: ~/Library/Application Support/Claude/claude_desktop_config.json

{
  "mcpServers": {
    "usaspending": {
      "command": "$stdio_server",
      "args": []
    }
  }
}

---
Codex CLI

Add this server (absolute path so it works from any cwd):

  codex mcp add usaspending -- "$stdio_server"

Inspect:

  codex mcp get usaspending --json
EOF

