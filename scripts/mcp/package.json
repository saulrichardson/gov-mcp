{
  "name": "usaspending-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP-ish server exposing USAspending profiles as tools/resources",
  "scripts": {
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "validate-profiles": "tsx src/validateProfiles.ts",
    "promote-profile": "tsx src/promoteProfile.ts",
    "smoke": "tsx src/smokeServer.ts",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "fast-glob": "^3.3.2",
    "undici": "^6.19.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.15.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
