# === Gov GPT environment template ===
# This file is intentionally minimal and forward-looking.
# Values marked REQUIRED should be set explicitly before running any probes or generators.

# --- Inputs: docs + live API ---
USASPENDING_BASE_URL=https://api.usaspending.gov          # REQUIRED host for live probes
USASPENDING_DOCS_DIR=usaspending-api                      # REQUIRED path to checked-out docs/submodule

# --- Probe behavior (fail-fast defaults) ---
PROBE_TIMEOUT_SECONDS=30                                  # REQUIRED per-request timeout in seconds
PROBE_MAX_CONCURRENCY=4                                   # REQUIRED number of concurrent probe requests
PROBE_USER_AGENT=gov-gpt-prober/0.1                       # Identifier sent with live probes

# --- Output locations ---
CONTRACTS_DIR=contracts                                   # Directory to write per-endpoint JSON contracts
PROBE_LOG_DIR=.cache/probe-logs                           # Where to stash raw request/response transcripts

# --- Logging / verbosity ---
LOG_LEVEL=INFO                                            # INFO|DEBUG; keep noise controllable

# --- Codex SDK / runner ---
CODEX_API_KEY=                                            # REQUIRED for Codex SDK
CODEX_MODEL=                                              # Optional override; blank uses default
CODEX_BASE_URL=                                           # Optional; blank uses default Codex API
CODEX_CONFIG_PATH=codex.config.json                       # Optional; path to per-repo Codex config (sandbox, tools)
