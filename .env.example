# === Gov GPT environment template (current pipeline) ===
#
# These variables are consumed by:
# - `src/agent/core/config.ts` (env + Codex config loader)
# - `scripts/codex/src/*.ts` runners (prompt templating)

# --- Live API host (used in prompts + emitted contract.endpoint.host) ---
USASPENDING_BASE_URL=https://api.usaspending.gov

# --- Codex SDK / runner ---
CODEX_API_KEY=
# Optional fallback alias if you standardize on OPENAI_* env vars.
OPENAI_API_KEY=
CODEX_MODEL=
# Optional fallback alias for model selection.
OPENAI_MODEL=
CODEX_BASE_URL=
# Optional fallback alias for base URL.
OPENAI_BASE_URL=
CODEX_CONFIG_PATH=codex.config.toml
